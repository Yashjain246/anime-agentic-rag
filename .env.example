# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your real values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Required API Keys ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
OMDB_API_KEY=your_omdb_api_key_here

# ── LangSmith (optional — set LANGSMITH_TRACING=true to enable) ──────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=anime-rag-prod

# ── Model Configuration ───────────────────────────────────────────────────────
# Embeddings run via fastembed (ONNX runtime, no torch/GPU needed) — both
# LORE_EMBEDDING_MODEL and RECS_EMBEDDING_MODEL default to bge-small-en-v1.5.
# LORE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# RECS_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2
LLM_MODEL=gemini-3.1-flash-lite

# ── Agent Behaviour ───────────────────────────────────────────────────────────
MAX_TOOL_ITERATIONS=5

# ── Google Calendar (optional) ────────────────────────────────────────────────
# Set to true after running: python scripts/calendar_auth.py
ENABLE_CALENDAR_TOOL=false

# ── Database (SQLite locally, Supabase PostgreSQL in production) ──────────────
DATABASE_URL=sqlite:///./chat_history.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Admin panel (optional) ─────────────────────────────────────────────────────
# Set a password to unlock a hidden "Admin" section in the sidebar with DB
# stats and a clear-all-history button. Leave empty/unset to disable it.
# ADMIN_PASSWORD=choose_a_strong_password
